@model user;
<header>
	<div class="header-area">
		<div id="sticky-header" class="main-header-area">
			<div class="container-fluid">
				<div class="header_bottom_border">
					<div class="row align-items-center">
						<div class="col-6 col-lg-2">
							<div class="logo">
								<img src="~/images/logo.png" style="max-width: 100%;" />
							</div>
						</div>
						<div class="col-xl-6 col-lg-7 d-none d-lg-block">
							<div class="main-menu d-none d-lg-block">
								<nav>
									<ul id="navigation">
										<li><a asp-action="Index" asp-controller="Home">My Lesson</a></li>
										<li><a asp-action="Index" asp-controller="Home">Главная панель</a></li>
										<li><a asp-action="Index" asp-controller="Home">Таблица</a></li>
										<li><a asp-action="Index" asp-controller="Home">Профиль</a></li>
									</ul>
								</nav>
							</div>
						</div>
						<div class="col-xl-3 col-lg-3 col-12 d-none d-lg-block">
							<div class="Appointment">
								<div class="phone_num">
									<a href="#">Log In</a>
								</div>
								<div>
									<a class="boxed-btn3">Sign In</a>
								</div>
							</div>
						</div>
						<div class="col-12 d-md-block">
							<div class="mobile_menu d-block d-lg-none"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</header>
<div class="slider_area">
	<div class="single_slider d-flex align-items-center slider_bg_1">
		<div class="container">
			<div class="row align-items-center">
				<div class="col-12 col-lg-7">
					<div class="slider_text">
						<div class="d-flex justify-content-between align-items-center mb-3 w-100">
							<h5 class="wow fadeInLeft mb-0" data-wow-duration="1s" data-wow-delay=".2s">
								My Lesson
							</h5>
							<div class="d-flex align-items-center d-lg-none ml-auto">
								<div class="phone_num mr-3">
									<a href="#" style="color: #fff; font-weight: 500; white-space: nowrap;">Log In</a>
								</div>
								<div>
									<a class="boxed-btn3" style="padding: 10px 20px; font-size: 14px; white-space: nowrap;">Sign In</a>
								</div>
							</div>
						</div>
						<div style="max-width: 500px;">
							<h3 class="wow fadeInLeft" data-wow-duration="1s" data-wow-delay=".3s">
								Удобное школьное расписание
							</h3>
							<p class="wow fadeInLeft" data-wow-duration="1s" data-wow-delay=".4s">
								MyLesson - сайт позволяющий составлять расписания для школы.
								Учитывает загруженность учителей и кабинетов...
							</p>
							<div class="sldier_btn wow fadeInLeft" data-wow-duration="1s" data-wow-delay=".5s">
								<a href="#" class="boxed-btn3">Начать работу</a>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
	<div class="ilstration_img wow fadeInRight d-none d-lg-block text-right"
		 data-wow-duration="1s"
		 data-wow-delay=".2s">
		<img src="~/images/banner/illustration.png" />
	</div>
</div>
<div class="popular_catagory_area">
   <div class="container">
     <div class="row">
       <div class="col-lg-12">
         <div class="section_title mb-40">
           <h3>Преимущества</h3>
         </div>
       </div>
     </div>
     <div class="row">
       <div class="col-lg-4 col-xl-3 col-md-6">
         <div class="single_catagory">
           <a href="jobs.html"><h4 class="">Интуитивно понятный дизайн</h4></a>
		   <p>Простой красивый, приятный глазу, дизайн, позволяющий быстро разобраться с прицнипом работы</p>
         </div>
       </div>
       <div class="col-lg-4 col-xl-3 col-md-6">
         <div class="single_catagory">
           <a href="jobs.html"><h4>Скорость и легкость работы</h4></a>
           <p>Сайт не перегружен лишним контентом, что положительно сказывается на производительности</p>
         </div>
       </div>
       <div class="col-lg-4 col-xl-3 col-md-6">
         <div class="single_catagory">
           <a href="jobs.html"><h4>Безопасность и приватность</h4></a>
           <p>Благодаря системе авторизации данные учителей и внутренний график скрыты от посторонних. </p>
         </div>
       </div>
       <div class="col-lg-4 col-xl-3 col-md-6">
         <div class="single_catagory">
           <a href="jobs.html"><h4>Адаптация под смартфоны</h4></a>
           <p>Сайт адаптирован так же и под мобильные устройства, из-за чего можно работать в любой точке где есть интернет.</p>
         </div>
       </div>
   </div>
</div>
</div>
<style>
	/* Заголовок как на фото */
.testimonial-title {
    font-size: 32px;
    color: #001d3d; /* Глубокий темно-синий */
    font-weight: 500;
    margin-bottom: 60px;
}

/* Текст цитаты */
.testimonial-text {
    font-size: 16px;
    line-height: 26px;
    color: #1a1a1a; /* Почти черный для читаемости */
    font-style: normal;
    margin-bottom: 15px;
    max-width: 500px;
}

/* Имя автора */
.author-name {
    font-size: 14px;
    color: #7a7a7a; /* Серый цвет */
    display: block;
}

/* Иконка кавычки (зеленый кружок как на фото) */
.quote_icon {
    position: absolute;
    bottom: 0;
    right: 0;
    width: 40px;
    height: 40px;
    background: #00d363; /* Тот самый зеленый */
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
}

/* Отступ между фото и текстом */
.ml-4 {
    margin-left: 30px;
}
</style>
<div class="testimonial-section py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 text-center">
                <div class="section_title mb-50">
                    <h3 class="testimonial-title">Testimonial</h3>
                </div>
            </div>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-10">
                <div class="testmonial_active owl-carousel">
                    <!-- Один слайд -->
                    <div class="single_testmonial d-flex align-items-center justify-content-center">
                        <div class="thumb position-relative">
                            <img src="@Url.Content("~/images/testmonial/author.png")" alt="Author" class="rounded-circle" style="width: 150px; height: 150px; object-fit: cover;">
                            <div class="quote_icon">
                                <i class="fa fa-quote-left"></i>
                            </div>
                        </div>
                        <div class="info ml-4">
                            <p class="testimonial-text">
                                "Working in conjunction with humanitarian aid agencies, we have supported 
                                programmes to help alleviate human suffering through animal welfare when 
                                people might depend on livestock as their only source of income or food."
                            </p>
                            <span class="author-name">- Micky Mouse</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

	<h1 class="text-dark m-2">У меня есть аккаунт</h1>
	<div class="segment">
		<form method="get" asp-action="Table" asp-controller="Home">
			<div class="row justify-content-center">
				<input asp-for="login" type="text" placeholder="Логин" value="user" class="input-group-text col-6 m-3" />
				<span asp-validation-for="login" class="col-6 text-danger"></span>
				<input asp-for="password" type="text" placeholder="Пароль" value="1234" class="input-group-text col-6 m-3" />
				<span asp-validation-for="password" class="col-6 text-danger"></span>
				<button class="btn btn-dark col-6 m-3">
					Войти
				</button>
			</div>
		</form>
	</div>
	<br />
	<h1 class="text-dark m-2" id="reg">Зарегистрироваться</h1>
	<div class="segment">
		<form asp-action="AddUser" asp-controller="Home">
			<div class="row justify-content-center">
				<input type="text" placeholder="Логин" class="input-group-text col-6 m-3" name="log" />
				<p class="col-6 text-danger">@ViewBag.MessageLog</p>
				<input type="text" placeholder="Пароль" class="input-group-text col-6 m-3" name="pass" />
				<p class="col-6 text-danger">@ViewBag.MessagePass</p>
				<button class="btn btn-dark col-6 m-3">
					Зарегистрироваться
				</button>
			</div>
		</form>
	</div>
	<h1 class="text-dark">Оставьте отзыв :)</h1>
	<div class="row segment justify-content-center">
		<div class="mb-3">
			<a class="text-dark text-decoration-none">Ваше имя</a>
			<input type="text" name="login" title="Ваше имя" class="form-control" style="width:100%;" />
		</div>
		<a class="text-dark text-decoration-none">Ваша оценка</a>
		<div class="d-flex justify-content-center gap-2">
			<img type="image" src="~/css/star.png" style="width:40px; height:40px;" class="mx-1" />
			<img type="image" src="~/css/star.png" style="width:40px; height:40px;" class="mx-1" />
			<img type="image" src="~/css/star.png" style="width:40px; height:40px;" class="mx-1" />
			<img type="image" src="~/css/star.png" style="width:40px; height:40px;" class="mx-1" />
			<img type="image" src="~/css/star.png" style="width:40px; height:40px;" class="mx-1" />
			<input type="hidden" value="0" id="value" name="price" />
		</div>
		<br />
		<a class="text-dark text-decoration-none">Ваше мнение</a>
		<div>
			<input type="text" name="text" title="Ваше мнение" class="form-control" style="width:100%;" />
		</div>
		<div class="row justify-content-center m-3">
			<button class="btn btn-dark text-light col-6" type="submit">Отправить отзыв</button>
		</div>
	</div>
