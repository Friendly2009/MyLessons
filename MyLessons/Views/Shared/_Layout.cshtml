<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MyLessons</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MyLessons.style.css" asp-append-version="true" />
</head>
<body>
@model user;
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-dark">
            <div class="container-fluid">
                <div class="d-flex align-items-center">
                    <h1 class="navbar-brand text-light mb-0">MyLessons</h1>
                    <form class="nav-link" asp-controller="Main" asp-action="MainPanel">
                        <button type="submit" class="btn btn-link text-decoration-none text-light p-0">Главная панель</button>
                    </form>
                    <form class="nav-link" asp-controller="Main" asp-action="Table">
                        <button type="submit" class="btn btn-link text-decoration-none text-light p-0">Таблица</button>
                    </form>
                </div>
                <div class="ms-auto">
                    <a class="nav-link text-light" asp-action="Index" asp-controller="Home">Выйти</a>
                </div>
            </div>
        </nav>
    </header>
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
    <footer class="bg-dark text-white py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-4">
                    <h5>О нас</h5>
                    <p>Мы помогаем создавать удобные и эффективные расписания для школ, чтобы учащиеся могли максимально использовать свое время.</p>
                </div>
                <div class="col-md-4">
                    <h5>Для вас</h5>
                    <ul class="list-unstyled">
                        <li><a asp-action="Index" asp-controller="Home" class="text-white">Главная</a></li>
                        <li><a asp-action="Support" asp-controller="Home" class="text-white">Контакты</a></li>
                        <li><a asp-action="UsersQuestion" asp-controller="Home" class="text-white">Часто задаваемые вопросы</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5>Контактная информация</h5>
                    <p>Email: myemail@example.com</p>
                    <p>Телефон: +7 999 99 99</p>
                    <p>Адрес: г. Москва, ул. Примерная, д. 1</p>
                </div>
            </div>
            <div class="text-center mt-4">
                <p>&copy; 2026 My Lesson. Все права защищены.</p>
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/JavaScript.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
