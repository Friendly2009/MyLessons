@model user;
@{user user = ViewBag.user;}
@if (TempData["message"] != null)
{
	<input id="obj" type="hidden" value="@TempData["message"]" />
	<script>
		var obj = document.getElementById("obj").getAttribute("value");
		alert(obj);
	</script>
}
<style>
	body {
		background-color: #f8f9fa;
	}

	.teacher-item {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}

	.nav-pills .nav-link {
		margin-right: 5px;
		margin-bottom: 5px;
		border: 1px solid #dee2e6;
	}
</style>
<header class="p-3 mb-3 border-bottom border-secondary text-white sticky-top shadow-sm" style="background: #001D38">
	<div class="container">
		<div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start">
			<a href="/" class="d-flex align-items-center mb-2 mb-lg-0 text-white text-decoration-none me-4">
				<h1 class="fs-4 fw-bold text-light">My Lesson</h1>
			</a>
			<ul class="nav col-12 col-lg-auto me-lg-auto mb-2 justify-content-center mb-md-0">
				<li><a href="/Main/MainPanel" class="nav-link px-3 text-white opacity-75 opacity-100-hover">Главная панель</a></li>
				<li><a href="/Main/Table" class="nav-link px-3 text-white opacity-75 opacity-100-hover">Таблица</a></li>
				<li><a href="/Main/MainPanel" class="nav-link px-3 text-white opacity-75 opacity-100-hover">Профиль</a></li>
			</ul>
		</div>
	</div>
</header>

<div class="container py-5">
	<div class="d-flex align-items-center mb-5">
		<div class="ms-3">
			<h2 class="mb-0">Администратор: @user.login</h2>
			<p class="text-muted mb-0">Главная Панель</p>
		</div>
	</div>

	<div class="row g-4">
		<!-- Панель учителей -->
		<div class="col-lg-4">
			<div class="card shadow-sm border-0">
				<div class="card-header bg-white py-3">
					<h5 class="card-title mb-0"><i class="bi bi-people me-2"></i>Список учителей</h5>
				</div>
				<div class="list-group list-group-flush">
					@for (int i = 0; i < ViewBag.teacher.Count; i++)
					{
						if (ViewBag.teacher[0] != "")
						{
							<div class="list-group-item teacher-item">
								<div>
									<div class="fw-bold">@ViewBag.objec[i]</div>
									<small class="text-muted">@ViewBag.teacher[i]</small>
								</div>
								<button class="btn btn-outline-danger btn-sm border-0"><i class="bi bi-trash"></i></button>
							</div>
						}
					}
				</div>
			</div>
		</div>

		<!-- Панель уроков -->
		<div class="col-lg-8">
			<div class="card shadow-sm border-0 mb-4">
				<div class="card-header bg-white py-3">
					<h5 class="card-title mb-0"><i class="bi bi-calendar3 me-2"></i>Расписание уроков</h5>
				</div>
				<div class="card-body">
					<!-- Кнопки выбора классов -->
					<ul class="nav nav-pills mb-4" id="classTabs" role="tablist">
						<li class="nav-item"><button class="nav-link active" data-bs-toggle="pill" data-bs-target="#class1A">1А</button></li>
						<li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#class2A">2А</button></li>
						<li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#class4B">4Б</button></li>
						<li class="nav-item"><button class="nav-link" data-bs-toggle="pill" data-bs-target="#class10A">10А</button></li>
					</ul>

					<!-- Таблица уроков -->
					<div class="tab-content">
						<div class="tab-pane fade show active" id="class1A">
							<div class="table-responsive">
								<table class="table align-middle">
									<thead class="table-light">
										<tr>
											<th>День</th>
											<th>№</th>
											<th>Предмет</th>
											<th>Учитель</th>
											<th>Действие</th>
										</tr>
									</thead>
									<tbody>
										<tr>
											<td>Понедельник</td>
											<td>1</td>
											<td>Математика</td>
											<td>Александр С. В.</td>
											<td><button class="btn btn-sm btn-light text-danger"><i class="bi bi-x-circle"></i></button></td>
										</tr>
									</tbody>
								</table>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- Форма добавления урока -->
			<div class="card shadow-sm border-0">
				<div class="card-header bg-white py-3">
					<h6 class="mb-0">Добавить новый урок</h6>
				</div>
				<div class="card-body">
					<form class="row g-3">
						<div class="col-md-3">
							<select class="form-select form-select-sm">
								<option selected>День недели</option>
								<option>Понедельник</option>
								<option>Вторник</option>
							</select>
						</div>
						<div class="col-md-2">
							<input type="number" class="form-control form-control-sm" placeholder="№ урока">
						</div>
						<div class="col-md-3">
							<input type="text" class="form-control form-control-sm" placeholder="Предмет">
						</div>
						<div class="col-md-4">
							<select class="form-select form-select-sm">
								<option selected>Выбрать учителя</option>
								@for (int i = 0; i < ViewBag.teacher.Count; i++)
									{
										if (ViewBag.teacher[0] != "")
										{
										<option>@ViewBag.teacher[i] @ViewBag.objec[i]</option>
										}
									}
								</select>
						</div>
						<div class="col-12">
							<button type="submit" class="btn btn-primary btn-sm px-4">Добавить в расписание</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>

