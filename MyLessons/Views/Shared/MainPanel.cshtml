@model user;
@{user user = ViewBag.user;}
@if (TempData["message"] != null)
{
	<input id="obj" type="hidden" value="@TempData["message"]" />
	<script>
		var obj = document.getElementById("obj").getAttribute("value");
		alert(obj);
	</script>
}
<header class="p-3 mb-3 border-bottom border-secondary text-white sticky-top shadow-sm" style="background: #001D38">
	<div class="container">
		<div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start">
			<a href="/" class="d-flex align-items-center mb-2 mb-lg-0 text-white text-decoration-none me-4">
				<h1 class="fs-4 fw-bold text-light">My Lesson</h1>
			</a>
			<ul class="nav col-12 col-lg-auto me-lg-auto mb-2 justify-content-center mb-md-0">
				<li><a href="/Main/MainPanel" class="nav-link px-3 text-white opacity-75 opacity-100-hover">Главная панель</a></li>
				<li><a href="/Main/Table" class="nav-link px-3 text-white opacity-75 opacity-100-hover">Таблица</a></li>
				<li><a href="/Main/MainPanel" class="nav-link px-3 text-white opacity-75 opacity-100-hover">Профиль</a></li>
			</ul>
		</div>
	</div>
</header>

<div class="container py-5">
	<div class="d-flex align-items-center mb-5">
		<div class="ms-3">
			<h2 class="mb-0">Администратор: @user.login</h2>
			<p class="text-muted mb-0">Главная Панель</p>
		</div>
	</div>

	<div class="row g-4">
		<div class="col-lg-4">
			<div class="card shadow-sm border-0">
				<div class="card-header bg-white py-3">
					<h5 class="card-title mb-0"><i class="bi bi-people me-2"></i>Список учителей</h5>
				</div>
				<div class="list-group list-group-flush">
					@for (int i = 0; i < ViewBag.teacher.Count; i++)
					{
						if (ViewBag.teacher[0] != "")
						{
							<div class="list-group-item teacher-item">
								<div>
									<div class="fw-bold">@ViewBag.objec[i]</div>
									<small class="text-muted">@ViewBag.teacher[i]</small>
								</div>
								<button class="btn btn-danger btn-sm border-0">X</button>
							</div>
						}
					}
				</div>
			</div>
		</div>
		<div class="col-lg-8">
			<div class="card shadow-sm border-0 mb-4">
				<div class="card-header bg-white py-3">
					<h5 class="card-title mb-0"><i class="bi bi-calendar3 me-2"></i>Расписание уроков</h5>
				</div>
				<div class="card-body">
					<ul class="nav nav-pills mb-4" id="classTabs" role="tablist">
						@foreach(var clas in ViewBag.classes)
						{
							<li class="nav-item">
								<form class="nav-link" asp-action="MainPanel" asp-controller="Main">
									<input type="hidden" value="@clas" name="clas"/>
									<button class="active btn btn-dark">@clas</button>
								</form>
							</li>
						}
						<li class="nav-item">
							<button class="active btn btn-dark" id="addClassBtn">+</button>
						</li>
					</ul>
					<h6>@ViewBag.clas</h6>
					<div class="tab-content">
						<div class="tab-pane fade show active">
							<div class="table-responsive">
								<table class="table align-middle">
									<thead class="table-light">
										<tr>
											<th>День</th>
											<th>№</th>
											<th>Предмет</th>
											<th>Учитель</th>
											<th>Аудитория</th>
											<th>Удалить</th>
										</tr>
									</thead>
									<tbody>
										@foreach(var obj in ViewBag.lesson)
										{
											<tr>
												<td>@obj.day</td>
												<td>@obj.number</td>
												<td>@obj.teacher</td>
												<td>@obj.less</td>
												<td>@obj.room</td>
												<td>
													<form asp-action="DeleteLesson" asp-controller="Main">
														<input type="hidden" name="less" value="@obj.less" />
														<input type="hidden" name="day" value="@obj.day" />
														<input type="hidden" name="number" value="@obj.number" />
														<input type="hidden" name="teacher" value="@obj.teacher" />
														<input type="hidden" name="clas" value="@obj.clas" />
														<input type="hidden" name="room" value="@obj.room" />
														<button class="btn btn-sm btn-outline-danger">X</button>
													</form>
												</td>
											</tr>
										}
									</tbody>
								</table>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="card shadow-sm border-0">
				<div class="card-header bg-white py-3">
					<h6 class="mb-0">Добавить новый урок</h6>
				</div>
				<div class="card-body">
					<form asp-action="AddLesson" asp-controller="Main" class="row g-3 justify-content-center">
						<div class="col-md-3">
							<select class="form-select form-select-sm form-control" name="day">
								<option selected>День недели</option>
								<option>1</option>
								<option>2</option>
								<option>3</option>
								<option>4</option>
								<option>5</option>
								<option>6</option>
							</select>
						</div>
						<div class="col-md-2">
							<input type="number" class="form-control form-control-sm" placeholder="№ урока" name="num">
						</div>
						<div class="col-md-2">
							<input type="number" class="form-control form-control-sm" placeholder="№ Аудитории" name="room">
						</div>
						<div class="col-md-4">
							<select class="form-select form-select-sm form-control" name="selectedSubject">
								<option selected>Выбрать учителя</option>
								@for (int i = 0; i < ViewBag.teacher.Count; i++)
								{
									if (ViewBag.teacher != null && ViewBag.teacher[i] != "")
									{
										string val = $"{ViewBag.objec[i]}|{ViewBag.teacher[i]}";
										<option value="@val	">@ViewBag.teacher[i] &nbsp; @ViewBag.objec[i]</option>
									}
								}
							</select>
						</div>
						<input type="hidden" name="clas" value="@ViewBag.clas"/>
						<div class="col-12 m-2">
							<button type="submit" class="btn boxed-btn3 btn-sm px-4">Добавить в расписание</button>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>

