@model user;
@{user user = ViewBag.user;}
@if (TempData["message"] != null)
{
	<input id="obj" type="hidden" value="@TempData["message"]" />
	<script>
		var obj = document.getElementById("obj").getAttribute("value");
		alert(obj);
	</script>
}
<header class="p-3 mb-3 border-bottom border-secondary text-white sticky-top shadow-sm" style="background: #001D38">
	<div class="container">
		<div class="d-flex flex-wrap align-items-center justify-content-center justify-content-lg-start">
			<a href="/" class="d-flex align-items-center mb-2 mb-lg-0 text-white text-decoration-none me-4">
				<h1 class="fs-4 fw-bold text-light">My Lesson</h1>
			</a>
			<ul class="nav col-12 col-lg-auto me-lg-auto mb-2 justify-content-center mb-md-0">
				<li><a href="/Main/MainPanel" class="nav-link px-3 text-white opacity-75 opacity-100-hover">Главная панель</a></li>
				<li><a href="/Main/Table" class="nav-link px-3 text-white opacity-75 opacity-100-hover">Таблица</a></li>
				<li><a href="/Main/MainPanel" class="nav-link px-3 text-white opacity-75 opacity-100-hover">Профиль</a></li>
			</ul>
		</div>
	</div>
</header>



<div class="justify-content-center row">
	<h1 class="col-12 text-center">Главная панель @user.login</h1>
</div>
<div class="container">
	<div class="row justify-content-center">
		<div class="col-8">
			@try
			{
				for (int i = 0; i < ViewBag.teacher.Count; i++)
				{
					if (ViewBag.teacher[0] != "")
					{
						<div class="row align-items-center mb-2 border-bottom pb-2 teacher-row">
							<div class="col-3 teacher-name" id="IdTeachersForNewLesson">@ViewBag.teachers[i]</div>
							<div class="col-3 teacher-subject" id="IdObjectForNewLesson">@ViewBag.objects[i]</div>
							<button class="btn btn-outline-dark btn-sm w-100 add-lesson-btn col-4" type="button" id="AddLesson">Назначить</button>
						</div>
					}
				}
			}
			catch
			{

			}
		</div>
	</div>
</div>

