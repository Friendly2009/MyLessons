<div id="customOverlay" class="custom-overlay">
	<div class="custom-modal-content p-4 bg-white rounded-4 shadow-lg">
		<div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2">
			<h5 class="fw-bold mb-0 text-dark">📅 Добавить занятие</h5>
			<button id="closeModal" type="button" class="btn btn-danger shadow-none" aria-label="Close">x</button>
		</div>
		<form asp-action="AddLesson" asp-controller="Main">
			<div class="row g-3">
				<div class="col-12">
					<label class="small text-muted mb-1">День недели</label>
					<select class="form-select" name="day" required>
						<option value="" disabled selected>Выберите день</option>
						<option value="1">Понедельник</option>
						<option value="2">Вторник</option>
						<option value="3">Среда</option>
						<option value="4">Четверг</option>
						<option value="5">Пятница</option>
						<option value="6">Суббота</option>
					</select>
				</div>
				<div class="col-12">
					<label class="small text-muted mb-1">Учитель и предмет</label>
					<select class="form-select" name="selectedSubject" required>
						<option value="" disabled selected>Выбрать из списка</option>
						@if (ViewBag.teacher != null)
						{
							for (int i = 0; i < ViewBag.teacher.Count; i++)
							{
								if (!string.IsNullOrEmpty(ViewBag.teacher[i]))
								{
									string val = $"{ViewBag.objec[i]}|{ViewBag.teacher[i]}";
									<option value="@val">@ViewBag.teacher[i] — @ViewBag.objec[i]</option>
								}
							}
						}
					</select>
				</div>
				<div class="col-12">
					<label class="small text-muted mb-1">Класс</label>
					<input type="text" class="form-control" name="clas" placeholder="Напр: 9-А" required />
				</div>
				<div class="col-6">
					<label class="small text-muted mb-1">№ урока</label>
					<input type="number" class="form-control" name="number" placeholder="1-8" min="1" max="10" />
				</div>
				<div class="col-6">
					<label class="small text-muted mb-1">Кабинет</label>
					<input type="number" class="form-control" name="room" placeholder="Каб." />
				</div>
			</div>
			<button type="submit" class="btn btn-primary w-100 mt-4 py-2 fw-bold">Добавить в расписание</button>
		</form>
	</div>
</div>